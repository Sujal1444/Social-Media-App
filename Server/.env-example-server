# ------------------------------------------------------------
# Environment configuration for Server (Node/Express)
# ------------------------------------------------------------

# Node environment
# Purpose: Sets the runtime environment (development, production, test)
NODE_ENV=development

# Server port
# Purpose: Port that the Express server listens on
PORT=4000

# Base URL
# Purpose: Canonical base URL of the server (useful for emails/redirects)
BASE_URL=http://localhost:4000

# CORS allowed origin
# Purpose: Origin allowed to access the API; set to client URL
CORS_ORIGIN=http://localhost:3000

# ------------------------------------------------------------
# MongoDB configuration
# ------------------------------------------------------------

# Local development database URI
# Purpose: Connection string for local MongoDB instance
MONGO_DB_LOCAL=mongodb://127.0.0.1:27017/social_media_app

# Production database URI (MongoDB Atlas example)
# Purpose: Connection string for production database
MONGO_DB_PROD=mongodb+srv://<username>:<password>@<cluster>/<db>?retryWrites=true&w=majority

# Active database URI used by the application
# Purpose: The app reads MONGO_DB from code in Server/index.js
# Note: dotenv does not expand nested variables; set the full URI directly
# Development:
MONGO_DB=mongodb://127.0.0.1:27017/social_media_app
# Production (example):
# MONGO_DB=mongodb+srv://<username>:<password>@<cluster>/<db>?retryWrites=true&w=majority

# ------------------------------------------------------------
# Authentication (JWT)
# ------------------------------------------------------------

# JWT secret key
# Purpose: Secret used to sign and verify JWT auth tokens (keep private!)
JWT_KEY=change_me_to_a_long_random_secret

# Token expiration (optional)
# Purpose: Expiration duration for JWT tokens (e.g., 7d, 12h)
JWT_EXPIRES_IN=7d

# ------------------------------------------------------------
# File uploads / storage
# ------------------------------------------------------------

# Upload directory
# Purpose: Directory for user-uploaded files (served under /images)
UPLOAD_DIR=public/uploads

# Static asset directory
# Purpose: Directory for static images/icons etc. (served under /static)
STATIC_DIR=public/static

# Storage driver
# Purpose: Choose where uploads are stored: local | cloudinary | s3
STORAGE_DRIVER=local

# ------------------------------------------------------------
# Cloudinary (if using cloud storage)
# ------------------------------------------------------------

# Cloudinary cloud name
# Purpose: Identifier for your Cloudinary account
CLOUDINARY_CLOUD_NAME=

# Cloudinary API key
# Purpose: API key for Cloudinary uploads/management
CLOUDINARY_API_KEY=

# Cloudinary API secret
# Purpose: Secret key for Cloudinary (keep private!)
CLOUDINARY_API_SECRET=

# Cloudinary upload preset (optional)
# Purpose: Named preset for unsigned uploads or default transformations
CLOUDINARY_UPLOAD_PRESET=

# ------------------------------------------------------------
# AWS S3 (alternative cloud storage)
# ------------------------------------------------------------

# AWS access key ID
# Purpose: IAM access key for S3 operations
AWS_ACCESS_KEY_ID=

# AWS secret access key
# Purpose: IAM secret key for S3 operations (keep private!)
AWS_SECRET_ACCESS_KEY=

# AWS region
# Purpose: Region of the S3 bucket (e.g., us-east-1)
AWS_REGION=

# AWS S3 bucket name
# Purpose: Target bucket for storing uploads
AWS_S3_BUCKET=

# ------------------------------------------------------------
# Email service (if applicable)
# ------------------------------------------------------------

# SMTP host
# Purpose: Email service host (e.g., smtp.sendgrid.net, smtp.gmail.com)
SMTP_HOST=

# SMTP port
# Purpose: Email service port (e.g., 587 for TLS, 465 for SSL)
SMTP_PORT=

# SMTP username
# Purpose: SMTP account username or API key
SMTP_USER=

# SMTP password
# Purpose: SMTP account password or API secret (keep private!)
SMTP_PASSWORD=

# SMTP secure
# Purpose: Use SSL/TLS (true/false)
SMTP_SECURE=false

# Default "From" name
# Purpose: Sender display name for outgoing emails
MAIL_FROM_NAME=Social Media App

# Default "From" address
# Purpose: Sender email address for outgoing emails
MAIL_FROM_ADDRESS=no-reply@example.com

# ------------------------------------------------------------
# Misc / diagnostics
# ------------------------------------------------------------

# Log level
# Purpose: Controls verbosity of logs: error | warn | info | debug
LOG_LEVEL=info