# ------------------------------------------------------------
# Environment configuration for Client (React)
# ------------------------------------------------------------

# Note: Create React App only exposes variables prefixed with REACT_APP_
# These are available at runtime via process.env.REACT_APP_*

# Base API URL
# Purpose: Root API endpoint used for axios/fetch requests from the client
# Note: The current code hardcodes http://localhost:4000; use this for future config
REACT_APP_API_BASE_URL=http://localhost:4000

# Public uploads base URL
# Purpose: Base URL for user-uploaded images served by the server
REACT_APP_PUBLIC_FOLDER=http://localhost:4000/images/

# Static assets base URL
# Purpose: Base URL for default images served by the server
REACT_APP_STATIC_FOLDER=http://localhost:4000/static/

# Cloudinary client configuration (optional)
# Purpose: If the client uploads directly to Cloudinary
REACT_APP_CLOUDINARY_CLOUD_NAME=
REACT_APP_CLOUDINARY_UPLOAD_PRESET=

# Feature flags / diagnostics (optional)
# Purpose: Enable client debug tools or verbose logging
REACT_APP_ENABLE_DEBUG=false